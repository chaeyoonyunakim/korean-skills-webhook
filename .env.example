# Slack incoming webhook URL — see README for how to create one.
# Never commit the real value; .env is gitignored.
# Format: https://hooks.slack.com/services/<team-id>/<bot-id>/<token>
SLACK_WEBHOOK_URL=

# Gemini API key for the optional rewrite-suggestion stage.
# Obtain from https://aistudio.google.com/app/apikey (free tier supported).
# Leave blank to disable rewrite suggestions (advisory scoring still runs).
GEMINI_API_KEY=

# Gemini model to use. Defaults to gemini-2.5-flash.
# Override if that model is unavailable on your key (e.g. gemini-flash-latest).
GEMINI_MODEL=gemini-2.5-flash

# Advisory score threshold (0–100) above which rewrite suggestions are generated.
# Default: 40. Set lower to see suggestions more often; set higher to reduce noise.
REWRITE_THRESHOLD=40
